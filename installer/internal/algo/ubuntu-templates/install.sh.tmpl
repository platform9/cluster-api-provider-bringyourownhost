#!/bin/bash
set -e
set -u
set -o pipefail

# Configuration
BUNDLE_DOWNLOAD_PATH={{.BundleDownloadPath}}
BUNDLE_ADDR={{.BundleAddrs}}
IMGPKG_VERSION={{.ImgpkgVersion}}
ARCH={{.Arch}}
BUNDLE_PATH=$BUNDLE_DOWNLOAD_PATH/$BUNDLE_ADDR

# Logging setup
LOG_FILE="/var/log/pf9/agent-upgrade-$(date +%Y%m%d-%H%M%S).log"
LOG_DIR=$(dirname "$LOG_FILE")
mkdir -p "$LOG_DIR"

exec > >(tee -a "$LOG_FILE") 2>&1

echo "=== Starting installation/upgrade at $(date) ==="

# Lock file to prevent concurrent execution
LOCK_FILE="/var/run/pf9-agent-upgrade.lock"

# Global variable for temporary directory
AGENT_TEMP_DIR=""

try_cleanup() {
    local exit_code=$?
    echo "=== Cleanup started with exit code: $exit_code ==="
    
    # Release the lock
    if [ -f "$LOCK_FILE" ]; then
        flock -u 200
        rm -f "$LOCK_FILE"
    fi
    
    # Clean up temporary files
    if [ -n "$AGENT_TEMP_DIR" ] && [ -d "$AGENT_TEMP_DIR" ]; then
        rm -rf "$AGENT_TEMP_DIR"
        echo "[INFO] Removed temporary directory: $AGENT_TEMP_DIR"
    fi
    
    echo "=== Cleanup completed ==="
    exit $exit_code
}

# Setup trap for cleanup
trap try_cleanup EXIT INT TERM

# Try to acquire lock
exec 200>"$LOCK_FILE"
if ! flock -n 200; then
    echo "Error: Another instance is already running. Exiting." >&2
    exit 1
fi

echo "=== Acquired lock, proceeding with installation/upgrade ==="


if ! command -v imgpkg >>/dev/null; then
    echo "[INFO] Installing imgpkg"	
    
    if command -v wget >>/dev/null; then
        dl_bin="wget -nv -O-"
    elif command -v curl >>/dev/null; then
        dl_bin="curl -s -L"
    else
        echo "[INFO] Installing curl"
        apt-get update && apt-get install -y curl
        dl_bin="curl -s -L"
    fi
    
    echo "[INFO] Downloading imgpkg..."
    $dl_bin https://github.com/vmware-tanzu/carvel-imgpkg/releases/download/$IMGPKG_VERSION/imgpkg-linux-$ARCH > /tmp/imgpkg
    mv /tmp/imgpkg /usr/local/bin/imgpkg
    chmod +x /usr/local/bin/imgpkg
    echo "[INFO] imgpkg installation complete"
fi

# --- BYOH Agent self-upgrade logic ---
upgrade_agent_if_needed() {
    local start_time=$(date +%s)
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] Starting agent upgrade check"
    
    if ! command -v imgpkg >/dev/null; then
        echo "[WARN] imgpkg not available, skipping agent upgrade check"
        return 0
    fi

    # Create a temporary directory for the agent files
    AGENT_TEMP_DIR=$(mktemp -d)
    echo "[INFO] Using temporary directory: $AGENT_TEMP_DIR"
    
    # Cleanup function for this scope
    cleanup() {
        local exit_code=$?
        echo "[INFO] Starting cleanup of temporary files"
        if [ -n "$AGENT_TEMP_DIR" ] && [ -d "$AGENT_TEMP_DIR" ]; then
            rm -rf "$AGENT_TEMP_DIR"
            echo "[INFO] Removed temporary directory: $AGENT_TEMP_DIR"
            AGENT_TEMP_DIR=""
        fi
        exit $exit_code
    }
    trap cleanup EXIT

    # Download the latest agent package
    echo "[INFO] Downloading latest agent package..."
    if ! imgpkg pull -i "quay.io/jayanthtjvrr/byoh-agent-deb:latest" -o "$AGENT_TEMP_DIR"; then
        echo "[ERROR] Failed to download agent package"
        return 1
    fi

    # Find the .deb file
    local latest_deb
    latest_deb=$(find "$AGENT_TEMP_DIR" -name "pf9-byohost-agent*.deb" | head -1)
    if [ -z "$latest_deb" ]; then
        echo "[ERROR] Could not find agent package in the downloaded image"
        return 1
    fi

    # Get package version for logging
    local pkg_ver
    pkg_ver=$(dpkg-deb -f "$latest_deb" Version)
    echo "[INFO] Installing agent package version: $pkg_ver"
    
    # Create a temporary script to handle the upgrade
    local upgrade_script
    upgrade_script=$(mktemp)
    
    # Create the upgrade script
    {
    echo '#!/bin/bash'
    echo 'set -euo pipefail'
    echo ''
    echo '# Log to stderr so it gets captured by nohup'
    echo 'log() {'
    echo '    echo "[$(date "+%Y-%m-%d %H:%M:%S")] $1" >&2'
    echo '}'
    echo ''
    echo 'LATEST_DEB=$1'
    echo 'MAX_RETRIES=3'
    echo ''
    echo 'log "=== Starting agent upgrade process ==="'
    echo ""
    echo '# Backup .byoh/config if it exists'
    echo 'if [ -f "$HOME/.byoh/config" ]; then'
    echo '    log "Backing up existing .byoh/config..."'
    echo '    mkdir -p /tmp/byoh-backup/'
    echo '    cp -a "$HOME/.byoh/config" "/tmp/byoh-backup/config.$(date +%s)" || log "[WARN] Failed to backup config"'
    echo 'fi'
    echo ''
    echo '# Install the package with force-confold to preserve existing configs'
    echo 'log "Stopping agent service before installation..."'
    echo 'systemctl stop pf9-byohost-agent 2>/dev/null || true'
    echo 'systemctl disable pf9-byohost-agent 2>/dev/null || true'
    echo ''
    echo 'log "Installing agent package..."'
    echo 'if ! DEBIAN_FRONTEND=noninteractive dpkg --force-confold -i "$LATEST_DEB"; then'
    echo '    log "dpkg reported errors, attempting to fix broken install..."'
    echo '    if ! DEBIAN_FRONTEND=noninteractive apt-get -f install -y; then'
    echo '        log "[ERROR] Failed to fix package installation"'
    echo '        exit 1'
    echo '    fi'
    echo 'fi'
    echo ''
    echo 'log "Agent package installed, configuring..."'
    echo ''
    echo '# Reload systemd to pick up any new unit files'
    echo 'log "Reloading systemd daemon..."'
    echo 'systemctl daemon-reload || log "[WARN] Failed to reload systemd"'
    echo ''
    echo '# Restore .byoh/config if it was backed up'
    echo 'if [ -d "/tmp/byoh-backup" ]; then'
    echo '    log "Restoring .byoh/config from backup..."'
    echo '    mkdir -p "$HOME/.byoh"'
    echo '    cp -a "/tmp/byoh-backup/"* "$HOME/.byoh/" 2>/dev/null || log "[WARN] Failed to restore some config files"'
    echo '    rm -rf /tmp/byoh-backup || true'
    echo 'fi'
    echo ''
    echo '# Start and enable the service'
    echo 'log "Starting agent service..."'
    echo '# Start and enable the service'
    echo 'attempt=1'
    echo 'while [ $attempt -le $MAX_RETRIES ]; do'
    echo '    log "Start attempt $attempt of $MAX_RETRIES..."'
    echo '    if systemctl enable --now pf9-byohost-agent; then'
    echo '        log "[SUCCESS] Agent service enabled and started"'
    echo '        exit 0'
    echo '    else'
    echo '        log "[WARN] Failed to enable service, attempting to start directly..."'
    echo '        systemctl start pf9-byohost-agent || log "[WARN] Failed to start service directly"'
    echo '    fi'
    echo '    if [ $attempt -eq $MAX_RETRIES ]; then'
    echo '        log "[ERROR] Failed to start agent service after $MAX_RETRIES attempts"'
    echo '        log "[DEBUG] Service status:"'
    echo '        systemctl status pf9-byohost-agent || true'
    echo '        exit 1'
    echo '    fi'
    echo '    log "Retrying in 5 seconds..."'
    echo '    sleep 5'
    echo '    attempt=$((attempt + 1))'
    echo 'done'
    } > "$upgrade_script"

    # Make the script executable
    chmod +x "$upgrade_script"
    
    echo "[DEBUG] Starting upgrade process in the foreground..."
    echo "[DEBUG] Upgrade script path: $upgrade_script"
    echo "[DEBUG] DEB file: $latest_deb"
    
    # Set up log file
    LOG_FILE="/var/log/pf9/agent-upgrade-$(date +%Y%m%d-%H%M%S).log"
    mkdir -p "$(dirname "$LOG_FILE")"
    touch "$LOG_FILE"
    
    # Run the upgrade script in the background and capture all output
    {
        echo "=== Starting upgrade process at $(date) ==="
        echo "Script: $upgrade_script"
        echo "DEB: $latest_deb"
        echo ""
        
        # Execute the script with debug output
        bash -x "$upgrade_script" "$latest_deb"
        
        echo ""
        echo "=== Upgrade process completed at $(date) ==="
    } >> "$LOG_FILE" 2>&1 &
    UPGRADE_PID=$!
    disown $UPGRADE_PID
    
    echo "[INFO] Upgrade process started in background with PID: $UPGRADE_PID"
    echo "[INFO] Logs: $LOG_FILE"
    
    # Clean up the script file after a delay
    (sleep 30 && rm -f "$upgrade_script") &
    
    # Return success immediately since we're running in background
    return 0
}
# --- End BYOH Agent self-upgrade logic ---


# Run agent upgrade if not already done
UPGRADE_MARKER="$HOME/.byoh/upgrade_complete"

# Check if upgrade has already been completed
if [ -f "$UPGRADE_MARKER" ]; then
    echo "[INFO] Upgrade already completed, skipping..."
else
    echo "[INFO] Starting agent upgrade process"
    if upgrade_agent_if_needed; then
        # Create marker file to indicate successful upgrade
        mkdir -p "$HOME/.byoh"
        touch "$UPGRADE_MARKER"
    else
        echo "[WARN] Agent upgrade encountered issues, but continuing with installation"
    fi
fi

echo "[INFO] Proceeding with bundle download"
mkdir -p $BUNDLE_PATH
imgpkg pull -i $BUNDLE_ADDR -o $BUNDLE_PATH

## disable swap
swapoff -a && sed -ri '/\sswap\s/s/^#?/#/' /etc/fstab

## disable firewall
if command -v ufw >>/dev/null; then
    ufw disable
fi

## load kernal modules
modprobe overlay && modprobe br_netfilter

## adding os configuration
tar -C / -xvf "$BUNDLE_PATH/conf.tar" && sysctl --system 

## installing deb packages
for pkg in cri-tools kubernetes-cni kubectl kubelet kubeadm; do
    dpkg --install "$BUNDLE_PATH/$pkg.deb" && apt-mark hold $pkg
done

## installing containerd
tar -C / -xvf "$BUNDLE_PATH/containerd.tar"
mkdir -p /etc/containerd
containerd config default > /etc/containerd/config.toml
{{.ContainerdConfig}}

## starting containerd service
systemctl daemon-reload && systemctl enable containerd && systemctl start containerd

echo "[SUCCESS] Installation complete!"
echo "=== Installation completed at $(date) ==="

# Clean up upgrade marker if it exists
if [ -f "$UPGRADE_MARKER" ]; then
    echo "[INFO] Cleaning up upgrade marker"
    rm -f "$UPGRADE_MARKER"
fi
